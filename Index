<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PIANO — Top-Down Shooter</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    width: 100%; height: 100%;
    background: #000;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    cursor: none;
    font-family: monospace;
  }
  #gameCanvas {
    display: block;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    cursor: none;
    max-width: 100vw;
    max-height: 100vh;
    aspect-ratio: 800 / 600;
  }
</style>
</head>
<body>
<canvas id="gameCanvas" width="800" height="600"></canvas>
<script>
'use strict';

// ============================================================
// SECTION 1: CONSTANTS & COLOR PALETTE
// ============================================================
const W = 800, H = 600;
const GRID = 16;
const FPS_CAP = 1 / 20;

const COL = {
  BG:           '#0a0a12',
  GRID:         '#12121e',
  PLAYER_BODY:  '#4adede',
  PLAYER_HELM:  '#2ab8c0',
  PLAYER_VISOR: '#88ffff',
  PLAYER_LEG:   '#2a7a8a',
  PLAYER_GUN:   '#aaffee',
  BULLET:       '#ffff44',
  BULLET_TRAIL: '#ffaa00',
  MUZZLE:       '#ffffff',
  SCOUT:        '#ff6eb4',
  SCOUT_DARK:   '#cc3380',
  BRUTE:        '#ff8c42',
  BRUTE_DARK:   '#b85c10',
  SPECTER:      '#a855f7',
  SPECTER_DARK: '#6b21a8',
  TANK:         '#4ade80',
  TANK_DARK:    '#166534',
  HP_BAR_BG:    '#1a1a2e',
  HP_BAR_FG:    '#22d3ee',
  HP_BAR_LOW:   '#ef4444',
  HEART:        '#ff4444',
  SCORE:        '#fbbf24',
  WHITE:        '#ffffff',
  DARK:         '#00000099',
  SCANLINE:     'rgba(0,0,0,0.18)',
  PARTICLE_SCOUT:   ['#ff6eb4','#ff99cc','#ff3399','#ffffff'],
  PARTICLE_BRUTE:   ['#ff8c42','#ffaa55','#ff6600','#ffdd88'],
  PARTICLE_SPECTER: ['#a855f7','#cc88ff','#7c3aed','#ffffff'],
  PARTICLE_TANK:    ['#4ade80','#88ffaa','#166534','#ffffff'],
  PARTICLE_PLAYER:  ['#4adede','#88ffff','#ffffff','#2ab8c0'],
};

// ============================================================
// SECTION 2: UTILITY
// ============================================================
function circlesOverlap(ax, ay, ar, bx, by, br) {
  const dx = ax - bx, dy = ay - by;
  return dx*dx + dy*dy < (ar+br)*(ar+br);
}

function fillPixelRect(ctx, x, y, w, h, col) {
  ctx.fillStyle = col;
  ctx.fillRect(Math.round(x), Math.round(y), w, h);
}

function clamp(v, lo, hi) { return v < lo ? lo : v > hi ? hi : v; }

function lerp(a, b, t) { return a + (b - a) * t; }

function rnd(lo, hi) { return lo + Math.random() * (hi - lo); }

function rndi(lo, hi) { return Math.floor(rnd(lo, hi + 1)); }

function normalizeVector(dx, dy) {
  const len = Math.sqrt(dx*dx + dy*dy);
  if (len === 0) return { x: 0, y: 0 };
  return { x: dx / len, y: dy / len };
}

function angToVec(a) { return { x: Math.cos(a), y: Math.sin(a) }; }

// ============================================================
// SECTION 3: INPUT HANDLER
// ============================================================
class InputHandler {
  constructor(canvas) {
    this.keys = {};
    this.mouseX = W / 2;
    this.mouseY = H / 2;
    this.isShooting = false;
    this._canvas = canvas;
    this._scale = 1;

    window.addEventListener('keydown', e => {
      this.keys[e.code] = true;
      this.keys[e.key] = true;
    });
    window.addEventListener('keyup', e => {
      this.keys[e.code] = false;
      this.keys[e.key] = false;
    });
    canvas.addEventListener('mousemove', e => {
      const rect = canvas.getBoundingClientRect();
      const scaleX = W / rect.width;
      const scaleY = H / rect.height;
      this.mouseX = (e.clientX - rect.left) * scaleX;
      this.mouseY = (e.clientY - rect.top) * scaleY;
    });
    canvas.addEventListener('mousedown', e => {
      if (e.button === 0) this.isShooting = true;
    });
    canvas.addEventListener('mouseup', e => {
      if (e.button === 0) this.isShooting = false;
    });
    canvas.addEventListener('contextmenu', e => e.preventDefault());
  }

  isDown(code) { return !!this.keys[code]; }

  getMovementVector() {
    let dx = 0, dy = 0;
    if (this.isDown('ArrowLeft')  || this.isDown('KeyA') || this.isDown('a')) dx -= 1;
    if (this.isDown('ArrowRight') || this.isDown('KeyD') || this.isDown('d')) dx += 1;
    if (this.isDown('ArrowUp')    || this.isDown('KeyW') || this.isDown('w')) dy -= 1;
    if (this.isDown('ArrowDown')  || this.isDown('KeyS') || this.isDown('s')) dy += 1;
    return normalizeVector(dx, dy);
  }

  justPressed(code) {
    // single-frame detection handled externally via polling
    return false;
  }
}

// ============================================================
// SECTION 4: DRAW FUNCTIONS
// ============================================================
function drawBackground(ctx) {
  fillPixelRect(ctx, 0, 0, W, H, COL.BG);
  ctx.strokeStyle = COL.GRID;
  ctx.lineWidth = 1;
  for (let x = 0; x < W; x += GRID) {
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
  }
  for (let y = 0; y < H; y += GRID) {
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
  }
}

function drawCrosshair(ctx, x, y) {
  const s = 10, g = 5;
  ctx.strokeStyle = '#00ffcc';
  ctx.lineWidth = 2;
  // horizontal
  ctx.beginPath(); ctx.moveTo(x - s - g, y); ctx.lineTo(x - g, y); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x + g, y); ctx.lineTo(x + s + g, y); ctx.stroke();
  // vertical
  ctx.beginPath(); ctx.moveTo(x, y - s - g); ctx.lineTo(x, y - g); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x, y + g); ctx.lineTo(x, y + s + g); ctx.stroke();
  // center dot
  ctx.fillStyle = '#00ffcc';
  ctx.fillRect(Math.round(x) - 1, Math.round(y) - 1, 3, 3);
}

function drawPlayer(ctx, x, y, angle, walkFrame, invTimer) {
  if (invTimer > 0 && Math.floor(invTimer * 14) % 2 === 0) return;

  ctx.save();
  ctx.translate(Math.round(x), Math.round(y));

  // Legs (animated)
  const legOff = Math.sin(walkFrame * Math.PI * 2) * 5;
  fillPixelRect(ctx, -4, 6, 4, 10, COL.PLAYER_LEG);   // left leg
  fillPixelRect(ctx, 1,  6, 4, 10, COL.PLAYER_LEG);    // right leg
  // leg animation
  fillPixelRect(ctx, -4, 10 + legOff, 4, 4, COL.PLAYER_LEG);
  fillPixelRect(ctx,  1, 10 - legOff, 4, 4, COL.PLAYER_LEG);

  // Body
  fillPixelRect(ctx, -8, -6, 16, 14, COL.PLAYER_BODY);

  // Helmet
  fillPixelRect(ctx, -7, -14, 14, 10, COL.PLAYER_HELM);
  // Visor
  fillPixelRect(ctx, -5, -12, 10, 6, COL.PLAYER_VISOR);

  // Gun (rotates with aim)
  ctx.save();
  ctx.rotate(angle);
  fillPixelRect(ctx, 6, -2, 12, 4, COL.PLAYER_GUN);
  fillPixelRect(ctx, 16, -1, 4, 2, COL.MUZZLE);
  ctx.restore();

  ctx.restore();
}

function drawScout(ctx, x, y, hp, maxHp) {
  ctx.save();
  ctx.translate(Math.round(x), Math.round(y));
  // Pointed triangle
  ctx.beginPath();
  ctx.moveTo(0, -14);
  ctx.lineTo(12, 10);
  ctx.lineTo(-12, 10);
  ctx.closePath();
  ctx.fillStyle = COL.SCOUT;
  ctx.fill();
  // inner
  ctx.beginPath();
  ctx.moveTo(0, -8);
  ctx.lineTo(6, 5);
  ctx.lineTo(-6, 5);
  ctx.closePath();
  ctx.fillStyle = COL.SCOUT_DARK;
  ctx.fill();
  // eye
  fillPixelRect(ctx, -2, -4, 4, 4, '#ffffff');
  drawEnemyHP(ctx, hp, maxHp, 0, 16, 24);
  ctx.restore();
}

function drawBrute(ctx, x, y, hp, maxHp) {
  ctx.save();
  ctx.translate(Math.round(x), Math.round(y));
  // Main block
  fillPixelRect(ctx, -14, -12, 28, 24, COL.BRUTE);
  fillPixelRect(ctx, -10, -8, 20, 16, COL.BRUTE_DARK);
  // Cannons
  fillPixelRect(ctx, -18, -4, 6, 8, COL.BRUTE_DARK);
  fillPixelRect(ctx,  12, -4, 6, 8, COL.BRUTE_DARK);
  // Eyes
  fillPixelRect(ctx, -6, -4, 4, 4, '#ffdd00');
  fillPixelRect(ctx,  2, -4, 4, 4, '#ffdd00');
  drawEnemyHP(ctx, hp, maxHp, 0, 18, 30);
  ctx.restore();
}

function drawSpecter(ctx, x, y, hp, maxHp, t) {
  ctx.save();
  ctx.translate(Math.round(x), Math.round(y));
  const pulse = 1 + Math.sin(t * 4) * 0.12;
  ctx.scale(pulse, pulse);
  // Ghost body
  ctx.beginPath();
  ctx.arc(0, -4, 12, Math.PI, 0);
  ctx.lineTo(12, 8);
  ctx.lineTo(8, 4);
  ctx.lineTo(4, 8);
  ctx.lineTo(0, 4);
  ctx.lineTo(-4, 8);
  ctx.lineTo(-8, 4);
  ctx.lineTo(-12, 8);
  ctx.closePath();
  ctx.fillStyle = COL.SPECTER;
  ctx.fill();
  // inner glow
  ctx.beginPath();
  ctx.arc(0, -4, 7, Math.PI, 0);
  ctx.fillStyle = COL.SPECTER_DARK;
  ctx.fill();
  // Eyes
  fillPixelRect(ctx, -6, -8, 4, 4, '#ffffff');
  fillPixelRect(ctx,  2, -8, 4, 4, '#ffffff');
  ctx.restore();
  drawEnemyHP(ctx, hp, maxHp, x, y + 18, 26);
  ctx.save();
  ctx.translate(Math.round(x), Math.round(y));
  ctx.restore();
}

function drawTank(ctx, x, y, hp, maxHp, angle, t) {
  ctx.save();
  ctx.translate(Math.round(x), Math.round(y));
  const pulse = 1 + Math.sin(t * 2) * 0.06;
  // Tracks
  fillPixelRect(ctx, -20, -16, 8, 32, COL.TANK_DARK);
  fillPixelRect(ctx,  12, -16, 8, 32, COL.TANK_DARK);
  // Body
  fillPixelRect(ctx, -14, -12, 28, 24, COL.TANK);
  fillPixelRect(ctx, -10, -8, 20, 16, COL.TANK_DARK);
  // Turret
  ctx.save();
  ctx.rotate(angle);
  fillPixelRect(ctx, -8, -8, 16, 16, COL.TANK);
  fillPixelRect(ctx,  7, -3,  16, 6, COL.TANK_DARK);
  ctx.restore();
  drawEnemyHP(ctx, hp, maxHp, 0, 22, 40);
  ctx.restore();
}

function drawEnemyHP(ctx, hp, maxHp, x, y, w) {
  // relative to current transform
  const h = 3;
  fillPixelRect(ctx, x - w/2, y, w, h, '#1a1a1a');
  const ratio = Math.max(0, hp / maxHp);
  const col = ratio > 0.5 ? '#22c55e' : ratio > 0.25 ? '#eab308' : '#ef4444';
  fillPixelRect(ctx, x - w/2, y, Math.round(w * ratio), h, col);
}

function drawBullet(ctx, x, y, trail) {
  // Trail
  for (let i = 0; i < trail.length; i++) {
    const t = i / trail.length;
    ctx.globalAlpha = t * 0.6;
    ctx.fillStyle = COL.BULLET_TRAIL;
    const r = 2 + t * 2;
    ctx.fillRect(Math.round(trail[i].x) - r/2, Math.round(trail[i].y) - r/2, r, r);
  }
  ctx.globalAlpha = 1;
  // Core
  ctx.fillStyle = COL.BULLET;
  ctx.fillRect(Math.round(x) - 3, Math.round(y) - 3, 6, 6);
  // Bright center
  ctx.fillStyle = '#ffffff';
  ctx.fillRect(Math.round(x) - 1, Math.round(y) - 1, 2, 2);
}

function drawMuzzleFlash(ctx, x, y, age) {
  if (age <= 0) return;
  const t = age / 0.06;
  ctx.globalAlpha = t;
  const r = 10 * t;
  // Circle
  ctx.fillStyle = '#ffffff';
  ctx.beginPath(); ctx.arc(x, y, r * 0.8, 0, Math.PI * 2); ctx.fill();
  // Spikes
  for (let i = 0; i < 3; i++) {
    const a = (i / 3) * Math.PI * 2;
    ctx.beginPath();
    ctx.moveTo(x, y);
    ctx.lineTo(x + Math.cos(a) * r * 1.8, y + Math.sin(a) * r * 1.8);
    ctx.lineTo(x + Math.cos(a + 0.3) * r * 0.8, y + Math.sin(a + 0.3) * r * 0.8);
    ctx.closePath();
    ctx.fillStyle = '#ffff88';
    ctx.fill();
  }
  ctx.globalAlpha = 1;
}

function drawParticle(ctx, p) {
  ctx.globalAlpha = p.alpha;
  ctx.fillStyle = p.col;
  const s = p.size;
  ctx.fillRect(Math.round(p.x) - s/2, Math.round(p.y) - s/2, s, s);
  ctx.globalAlpha = 1;
}

function drawHUD(ctx, player, score, level, wave, totalWaves) {
  // HP bar background
  fillPixelRect(ctx, 10, H - 28, 160, 14, COL.HP_BAR_BG);
  const hpRatio = Math.max(0, player.hp / player.maxHp);
  const hpCol = hpRatio > 0.5 ? COL.HP_BAR_FG : hpRatio > 0.25 ? '#f59e0b' : COL.HP_BAR_LOW;
  fillPixelRect(ctx, 10, H - 28, Math.round(160 * hpRatio), 14, hpCol);
  ctx.strokeStyle = '#334155';
  ctx.lineWidth = 1;
  ctx.strokeRect(10, H - 28, 160, 14);

  // HP label
  ctx.fillStyle = COL.WHITE;
  ctx.font = '8px monospace';
  ctx.textAlign = 'left';
  ctx.fillText(`HP ${player.hp}/${player.maxHp}`, 14, H - 18);

  // Lives (hearts)
  for (let i = 0; i < player.lives; i++) {
    drawHeart(ctx, 180 + i * 20, H - 22);
  }

  // Score
  ctx.fillStyle = COL.SCORE;
  ctx.font = 'bold 14px monospace';
  ctx.textAlign = 'right';
  ctx.fillText(`SCORE ${String(score).padStart(7, '0')}`, W - 10, H - 16);

  // Level / Wave
  ctx.fillStyle = COL.WHITE;
  ctx.font = '10px monospace';
  ctx.textAlign = 'center';
  ctx.fillText(`LVL ${level}  WAVE ${wave}/${totalWaves}`, W / 2, H - 16);
}

function drawHeart(ctx, cx, cy) {
  ctx.fillStyle = COL.HEART;
  // pixelated heart
  const p = [
    [1,0],[2,0],[4,0],[5,0],
    [0,1],[1,1],[2,1],[3,1],[4,1],[5,1],[6,1],
    [0,2],[1,2],[2,2],[3,2],[4,2],[5,2],[6,2],
    [1,3],[2,3],[3,3],[4,3],[5,3],
    [2,4],[3,4],[4,4],
    [3,5],
  ];
  for (const [dx, dy] of p) {
    ctx.fillRect(cx - 3 + dx, cy + dy - 3, 1, 1);
  }
}

function drawScanlines(ctx) {
  ctx.fillStyle = COL.SCANLINE;
  for (let y = 0; y < H; y += 4) {
    ctx.fillRect(0, y, W, 2);
  }
}

function drawPixelText(ctx, text, x, y, size, col, align) {
  ctx.fillStyle = col || COL.WHITE;
  ctx.font = `bold ${size || 16}px monospace`;
  ctx.textAlign = align || 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(text, x, y);
}

// ============================================================
// SECTION 5: ENTITY CLASSES
// ============================================================

// --- Particle Pool ---
class ParticlePool {
  constructor(maxCount) {
    this.pool = [];
    this.active = [];
    for (let i = 0; i < maxCount; i++) {
      this.pool.push({
        x: 0, y: 0, vx: 0, vy: 0,
        alpha: 0, col: '#fff', size: 3, life: 0, maxLife: 0,
        alive: false
      });
    }
  }

  spawn(x, y, vx, vy, col, size, life) {
    const p = this.pool.pop();
    if (!p) return;
    p.x = x; p.y = y;
    p.vx = vx; p.vy = vy;
    p.col = col;
    p.size = size;
    p.life = life; p.maxLife = life;
    p.alpha = 1;
    p.alive = true;
    this.active.push(p);
  }

  spawnExplosion(x, y, colors, count, speed, life) {
    for (let i = 0; i < count; i++) {
      const a = rnd(0, Math.PI * 2);
      const s = rnd(speed * 0.3, speed);
      const col = colors[rndi(0, colors.length - 1)];
      const sz = rnd(2, 5);
      const lt = rnd(life * 0.5, life);
      this.spawn(x, y, Math.cos(a) * s, Math.sin(a) * s, col, sz, lt);
    }
  }

  update(dt) {
    for (let i = this.active.length - 1; i >= 0; i--) {
      const p = this.active[i];
      p.x += p.vx * dt;
      p.y += p.vy * dt;
      p.vx *= (1 - dt * 4);
      p.vy *= (1 - dt * 4);
      p.life -= dt;
      p.alpha = Math.max(0, p.life / p.maxLife);
      if (p.life <= 0) {
        p.alive = false;
        this.active.splice(i, 1);
        this.pool.push(p);
      }
    }
  }

  render(ctx) {
    for (const p of this.active) {
      drawParticle(ctx, p);
    }
  }
}

// --- Bullet ---
class Bullet {
  constructor(x, y, angle, speed, damage, owner) {
    this.x = x; this.y = y;
    this.vx = Math.cos(angle) * speed;
    this.vy = Math.sin(angle) * speed;
    this.damage = damage;
    this.owner = owner; // 'player' or 'enemy'
    this.radius = 4;
    this.alive = true;
    this.trail = [];
    this.maxTrail = 8;
  }

  update(dt) {
    this.trail.push({ x: this.x, y: this.y });
    if (this.trail.length > this.maxTrail) this.trail.shift();

    this.x += this.vx * dt;
    this.y += this.vy * dt;

    if (this.x < -20 || this.x > W + 20 || this.y < -20 || this.y > H + 20) {
      this.alive = false;
    }
  }

  render(ctx) {
    drawBullet(ctx, this.x, this.y, this.trail);
  }
}

// --- Player ---
class Player {
  constructor() {
    this.reset();
  }

  reset() {
    this.x = W / 2;
    this.y = H / 2;
    this.speed = 180;
    this.hp = 100;
    this.maxHp = 100;
    this.lives = 3;
    this.angle = 0;
    this.invTimer = 0;
    this.walkFrame = 0;
    this.walkTimer = 0;
    this.radius = 14;
    this.fireCooldown = 0;
    this.fireRate = 0.15;
    this.muzzleFlashAge = 0;
    this.isMoving = false;
    this.alive = true;
  }

  update(dt, input, bullets) {
    const move = input.getMovementVector();
    this.isMoving = (move.x !== 0 || move.y !== 0);

    this.x = clamp(this.x + move.x * this.speed * dt, this.radius, W - this.radius);
    this.y = clamp(this.y + move.y * this.speed * dt, this.radius, H - this.radius);

    // Walk animation
    if (this.isMoving) {
      this.walkTimer += dt;
      if (this.walkTimer >= 0.1) {
        this.walkTimer = 0;
        this.walkFrame = (this.walkFrame + 0.25) % 1;
      }
    }

    // Aim
    const dx = input.mouseX - this.x;
    const dy = input.mouseY - this.y;
    this.angle = Math.atan2(dy, dx);

    // Invincibility
    if (this.invTimer > 0) this.invTimer -= dt;

    // Muzzle flash
    if (this.muzzleFlashAge > 0) this.muzzleFlashAge -= dt;

    // Fire
    if (this.fireCooldown > 0) this.fireCooldown -= dt;
    if (input.isShooting && this.fireCooldown <= 0) {
      this.shoot(bullets);
    }
  }

  shoot(bullets) {
    const gunTipX = this.x + Math.cos(this.angle) * 20;
    const gunTipY = this.y + Math.sin(this.angle) * 20;
    bullets.push(new Bullet(gunTipX, gunTipY, this.angle, 600, 20, 'player'));
    this.fireCooldown = this.fireRate;
    this.muzzleFlashAge = 0.06;
  }

  takeDamage(amount, particles) {
    if (this.invTimer > 0) return false;
    this.hp -= amount;
    this.invTimer = 2.0;
    particles.spawnExplosion(this.x, this.y, COL.PARTICLE_PLAYER, 12, 120, 0.5);
    if (this.hp <= 0) {
      this.hp = 0;
      this.lives--;
      if (this.lives > 0) {
        this.hp = this.maxHp;
        this.invTimer = 3.0;
      } else {
        this.alive = false;
      }
    }
    return true;
  }

  getMuzzlePos() {
    return {
      x: this.x + Math.cos(this.angle) * 22,
      y: this.y + Math.sin(this.angle) * 22
    };
  }

  render(ctx) {
    drawPlayer(ctx, this.x, this.y, this.angle, this.walkFrame, this.invTimer);
    if (this.muzzleFlashAge > 0) {
      const mp = this.getMuzzlePos();
      drawMuzzleFlash(ctx, mp.x, mp.y, this.muzzleFlashAge);
    }
  }
}

// --- Enemy base ---
class Enemy {
  constructor(x, y, hp, speed, damage, points, radius, type) {
    this.x = x; this.y = y;
    this.hp = hp; this.maxHp = hp;
    this.speed = speed;
    this.damage = damage;
    this.points = points;
    this.radius = radius;
    this.type = type;
    this.alive = true;
    this.angle = 0;
    this.t = Math.random() * 100;
  }

  update(dt, player) {
    this.t += dt;
    const dx = player.x - this.x;
    const dy = player.y - this.y;
    const dir = normalizeVector(dx, dy);
    this.x += dir.x * this.speed * dt;
    this.y += dir.y * this.speed * dt;
    this.angle = Math.atan2(dy, dx);
  }

  takeDamage(amount) {
    this.hp -= amount;
    if (this.hp <= 0) {
      this.hp = 0;
      this.alive = false;
      return true; // died
    }
    return false;
  }

  render(ctx) { /* overridden */ }
}

class Scout extends Enemy {
  constructor(x, y) {
    super(x, y, 30, 120, 10, 50, 12, 'scout');
  }
  render(ctx) {
    drawScout(ctx, this.x, this.y, this.hp, this.maxHp);
  }
}

class Brute extends Enemy {
  constructor(x, y) {
    super(x, y, 120, 60, 25, 150, 18, 'brute');
  }
  render(ctx) {
    drawBrute(ctx, this.x, this.y, this.hp, this.maxHp);
  }
}

class Specter extends Enemy {
  constructor(x, y) {
    super(x, y, 45, 180, 15, 100, 13, 'specter');
    this.angleOffset = rnd(-0.5, 0.5);
  }
  update(dt, player) {
    this.t += dt;
    const dx = player.x - this.x;
    const dy = player.y - this.y;
    const base = Math.atan2(dy, dx);
    const jitter = Math.sin(this.t * 3.5) * 0.6 + this.angleOffset;
    const a = base + jitter;
    this.x += Math.cos(a) * this.speed * dt;
    this.y += Math.sin(a) * this.speed * dt;
    this.angle = a;
  }
  render(ctx) {
    drawSpecter(ctx, this.x, this.y, this.hp, this.maxHp, this.t);
  }
}

class Tank extends Enemy {
  constructor(x, y) {
    super(x, y, 300, 35, 40, 300, 24, 'tank');
  }
  render(ctx) {
    drawTank(ctx, this.x, this.y, this.hp, this.maxHp, this.angle, this.t);
  }
}

function spawnEnemyAtBorder(type) {
  const side = rndi(0, 3);
  let x, y;
  if (side === 0) { x = rnd(0, W); y = -30; }
  else if (side === 1) { x = W + 30; y = rnd(0, H); }
  else if (side === 2) { x = rnd(0, W); y = H + 30; }
  else { x = -30; y = rnd(0, H); }

  switch (type) {
    case 'scout':   return new Scout(x, y);
    case 'brute':   return new Brute(x, y);
    case 'specter': return new Specter(x, y);
    case 'tank':    return new Tank(x, y);
  }
}

function getParticleColors(type) {
  switch (type) {
    case 'scout':   return COL.PARTICLE_SCOUT;
    case 'brute':   return COL.PARTICLE_BRUTE;
    case 'specter': return COL.PARTICLE_SPECTER;
    case 'tank':    return COL.PARTICLE_TANK;
    default:        return COL.PARTICLE_PLAYER;
  }
}

// ============================================================
// SECTION 6: LEVEL DEFINITIONS
// ============================================================
const LEVELS = [
  {
    title: 'SECTOR 1',
    waves: [
      { scouts: 5, brutes: 0, specters: 0, tanks: 0 },
      { scouts: 8, brutes: 0, specters: 0, tanks: 0 },
      { scouts: 12, brutes: 0, specters: 0, tanks: 0 },
    ],
    bonus: 500
  },
  {
    title: 'SECTOR 2',
    waves: [
      { scouts: 5, brutes: 2, specters: 0, tanks: 0 },
      { scouts: 6, brutes: 3, specters: 0, tanks: 0 },
      { scouts: 8, brutes: 4, specters: 0, tanks: 0 },
      { scouts: 10, brutes: 4, specters: 0, tanks: 0 },
    ],
    bonus: 1000
  },
  {
    title: 'SECTOR 3',
    waves: [
      { scouts: 6, brutes: 2, specters: 3, tanks: 0 },
      { scouts: 8, brutes: 3, specters: 4, tanks: 0 },
      { scouts: 10, brutes: 4, specters: 5, tanks: 0 },
    ],
    bonus: 1500
  },
  {
    title: 'SECTOR 4',
    waves: [
      { scouts: 6, brutes: 3, specters: 3, tanks: 1 },
      { scouts: 8, brutes: 4, specters: 4, tanks: 1 },
      { scouts: 10, brutes: 5, specters: 5, tanks: 2 },
      { scouts: 12, brutes: 6, specters: 6, tanks: 2 },
    ],
    bonus: 2000
  },
];

function getEndlessWave(waveIndex) {
  const diff = Math.floor(waveIndex / 3);
  return {
    scouts:   4 + diff * 3,
    brutes:   2 + diff * 2,
    specters: 2 + diff * 2,
    tanks:    Math.floor(diff * 0.8)
  };
}

// ============================================================
// SECTION 7: WAVE MANAGER
// ============================================================
class WaveManager {
  constructor() {
    this.enemies = [];
    this.spawnQueue = [];
    this.spawnTimer = 0;
    this.spawnInterval = 0.6;
    this.waveComplete = false;
  }

  loadWave(waveDef) {
    this.spawnQueue = [];
    this.waveComplete = false;
    for (let i = 0; i < (waveDef.scouts || 0); i++)   this.spawnQueue.push('scout');
    for (let i = 0; i < (waveDef.brutes || 0); i++)   this.spawnQueue.push('brute');
    for (let i = 0; i < (waveDef.specters || 0); i++) this.spawnQueue.push('specter');
    for (let i = 0; i < (waveDef.tanks || 0); i++)    this.spawnQueue.push('tank');
    // Shuffle
    for (let i = this.spawnQueue.length - 1; i > 0; i--) {
      const j = rndi(0, i);
      [this.spawnQueue[i], this.spawnQueue[j]] = [this.spawnQueue[j], this.spawnQueue[i]];
    }
    this.spawnTimer = 0;
  }

  update(dt, player, bullets, particles, addScore) {
    // Spawn
    this.spawnTimer -= dt;
    if (this.spawnTimer <= 0 && this.spawnQueue.length > 0) {
      const type = this.spawnQueue.pop();
      this.enemies.push(spawnEnemyAtBorder(type));
      this.spawnTimer = this.spawnInterval;
    }

    // Update enemies
    for (let i = this.enemies.length - 1; i >= 0; i--) {
      const e = this.enemies[i];
      e.update(dt, player);

      // Bullet collision
      for (let j = bullets.length - 1; j >= 0; j--) {
        const b = bullets[j];
        if (b.owner !== 'player') continue;
        if (circlesOverlap(e.x, e.y, e.radius, b.x, b.y, b.radius)) {
          b.alive = false;
          const died = e.takeDamage(b.damage);
          if (died) {
            particles.spawnExplosion(e.x, e.y, getParticleColors(e.type), 20, 160, 0.8);
            addScore(e.points);
            this.enemies.splice(i, 1);
          }
          break;
        }
      }

      // Player collision
      if (e.alive && circlesOverlap(e.x, e.y, e.radius, player.x, player.y, player.radius)) {
        player.takeDamage(e.damage, particles);
      }
    }

    // Wave complete?
    if (this.spawnQueue.length === 0 && this.enemies.length === 0) {
      this.waveComplete = true;
    }
  }

  render(ctx) {
    for (const e of this.enemies) e.render(ctx);
  }

  clear() {
    this.enemies = [];
    this.spawnQueue = [];
    this.waveComplete = false;
  }
}

// ============================================================
// SECTION 8: SCREEN SHAKE
// ============================================================
class ScreenShake {
  constructor() {
    this.trauma = 0;
    this.maxOffset = 18;
    this.decay = 1.8;
  }

  add(amount) {
    this.trauma = Math.min(1, this.trauma + amount);
  }

  update(dt) {
    this.trauma = Math.max(0, this.trauma - this.decay * dt);
  }

  apply(ctx) {
    if (this.trauma <= 0) return;
    const s = this.trauma * this.trauma;
    const ox = (Math.random() * 2 - 1) * this.maxOffset * s;
    const oy = (Math.random() * 2 - 1) * this.maxOffset * s;
    ctx.translate(ox, oy);
  }
}

// ============================================================
// SECTION 9: DEMO ENEMIES (MENU)
// ============================================================
class DemoEnemy {
  constructor() {
    this.reset();
  }
  reset() {
    const side = rndi(0, 3);
    if (side === 0) { this.x = rnd(0, W); this.y = -30; this.vx = rnd(-40, 40); this.vy = rnd(40, 80); }
    else if (side === 1) { this.x = W + 30; this.y = rnd(0, H); this.vx = rnd(-80, -40); this.vy = rnd(-40, 40); }
    else if (side === 2) { this.x = rnd(0, W); this.y = H + 30; this.vx = rnd(-40, 40); this.vy = rnd(-80, -40); }
    else { this.x = -30; this.y = rnd(0, H); this.vx = rnd(40, 80); this.vy = rnd(-40, 40); }
    this.type = ['scout', 'brute', 'specter', 'tank'][rndi(0, 3)];
    this.t = rnd(0, 100);
  }
  update(dt) {
    this.t += dt;
    this.x += this.vx * dt;
    this.y += this.vy * dt;
    if (this.x < -60 || this.x > W + 60 || this.y < -60 || this.y > H + 60) this.reset();
  }
  render(ctx) {
    ctx.globalAlpha = 0.3;
    switch (this.type) {
      case 'scout':   drawScout(ctx, this.x, this.y, 30, 30); break;
      case 'brute':   drawBrute(ctx, this.x, this.y, 120, 120); break;
      case 'specter': drawSpecter(ctx, this.x, this.y, 45, 45, this.t); break;
      case 'tank':    drawTank(ctx, this.x, this.y, 300, 300, 0, this.t); break;
    }
    ctx.globalAlpha = 1;
  }
}

// ============================================================
// SECTION 10: GAME STATES
// ============================================================
const STATE = {
  MENU: 'MENU',
  HOWTOPLAY: 'HOWTOPLAY',
  PLAYING: 'PLAYING',
  LEVELCLEAR: 'LEVELCLEAR',
  GAMEOVER: 'GAMEOVER',
};

// ============================================================
// SECTION 11: MAIN GAME
// ============================================================
class Game {
  constructor(canvas) {
    this.canvas = canvas;
    this.ctx = canvas.getContext('2d');
    this.input = new InputHandler(canvas);
    this.particles = new ParticlePool(500);
    this.shake = new ScreenShake();
    this.waveManager = new WaveManager();

    // State
    this.state = STATE.MENU;
    this.prevKeys = {};

    // Gameplay
    this.player = new Player();
    this.bullets = [];
    this.score = 0;
    this.levelIndex = 0;
    this.waveIndex = 0;
    this.isEndless = false;
    this.endless_waveIndex = 0;

    // Level clear
    this.levelClearTimer = 0;
    this.levelClearBonus = 0;

    // Menu
    this.demoEnemies = Array.from({ length: 6 }, () => new DemoEnemy());
    this.titleTimer = 0;
    this.menuBlink = 0;

    // Game over
    this.finalScore = 0;
    this.finalLevel = 0;

    // Timing
    this.lastTime = performance.now();
  }

  // Key press detection
  justPressed(code) {
    return !!(this.input.keys[code] && !this.prevKeys[code]);
  }

  addScore(pts) {
    this.score += pts;
    this.shake.add(0.1);
  }

  startGame() {
    this.player.reset();
    this.bullets = [];
    this.score = 0;
    this.levelIndex = 0;
    this.waveIndex = 0;
    this.isEndless = false;
    this.endless_waveIndex = 0;
    this.waveManager.clear();
    this.particles = new ParticlePool(500);
    this.loadCurrentWave();
    this.state = STATE.PLAYING;
  }

  loadCurrentWave() {
    let waveDef;
    if (this.isEndless) {
      waveDef = getEndlessWave(this.endless_waveIndex);
    } else {
      const level = LEVELS[this.levelIndex];
      waveDef = level.waves[this.waveIndex];
    }
    this.waveManager.loadWave(waveDef);
  }

  getCurrentLevelTitle() {
    if (this.isEndless) return 'SECTOR X';
    return LEVELS[this.levelIndex]?.title || 'SECTOR X';
  }

  getCurrentWaveDisplay() {
    if (this.isEndless) return this.endless_waveIndex + 1;
    return this.waveIndex + 1;
  }

  getTotalWaves() {
    if (this.isEndless) return '∞';
    return LEVELS[this.levelIndex]?.waves.length || 1;
  }

  update(dt) {
    this.titleTimer += dt;
    this.menuBlink += dt;

    switch (this.state) {
      case STATE.MENU:       this.updateMenu(dt); break;
      case STATE.HOWTOPLAY:  this.updateHowToPlay(dt); break;
      case STATE.PLAYING:    this.updatePlaying(dt); break;
      case STATE.LEVELCLEAR: this.updateLevelClear(dt); break;
      case STATE.GAMEOVER:   this.updateGameOver(dt); break;
    }

    // Store previous key state
    this.prevKeys = Object.assign({}, this.input.keys);
  }

  updateMenu(dt) {
    for (const e of this.demoEnemies) e.update(dt);
    if (this.justPressed('Enter')) this.startGame();
    if (this.justPressed('KeyH') || this.justPressed('h')) this.state = STATE.HOWTOPLAY;
  }

  updateHowToPlay(dt) {
    if (this.justPressed('Escape') || this.justPressed('Enter')) this.state = STATE.MENU;
  }

  updatePlaying(dt) {
    if (this.justPressed('Escape')) {
      this.state = STATE.MENU;
      return;
    }

    this.shake.update(dt);
    this.particles.update(dt);
    this.player.update(dt, this.input, this.bullets);

    // Update bullets
    for (let i = this.bullets.length - 1; i >= 0; i--) {
      this.bullets[i].update(dt);
      if (!this.bullets[i].alive) this.bullets.splice(i, 1);
    }

    // Wave manager
    const prevHp = this.player.hp;
    this.waveManager.update(dt, this.player, this.bullets, this.particles, (pts) => this.addScore(pts));

    // Shake on player damage
    if (this.player.hp < prevHp) this.shake.add(0.5);

    // Player dead?
    if (!this.player.alive) {
      this.finalScore = this.score;
      this.finalLevel = this.levelIndex + 1;
      this.state = STATE.GAMEOVER;
      return;
    }

    // Wave clear?
    if (this.waveManager.waveComplete) {
      this.waveManager.clear();
      this.advanceWave();
    }
  }

  advanceWave() {
    if (this.isEndless) {
      this.endless_waveIndex++;
      this.loadCurrentWave();
      return;
    }

    const level = LEVELS[this.levelIndex];
    this.waveIndex++;

    if (this.waveIndex >= level.waves.length) {
      // Level complete
      this.levelClearBonus = level.bonus;
      this.score += this.levelClearBonus;
      this.levelClearTimer = 3.5;
      this.state = STATE.LEVELCLEAR;
    } else {
      this.loadCurrentWave();
    }
  }

  updateLevelClear(dt) {
    this.levelClearTimer -= dt;
    if (this.levelClearTimer <= 0 || this.justPressed('Enter')) {
      this.levelIndex++;
      this.waveIndex = 0;
      if (this.levelIndex >= LEVELS.length) {
        this.isEndless = true;
        this.endless_waveIndex = 0;
      }
      this.loadCurrentWave();
      this.state = STATE.PLAYING;
    }
  }

  updateGameOver(dt) {
    if (this.justPressed('Enter')) {
      this.startGame();
    }
    if (this.justPressed('Escape')) {
      this.state = STATE.MENU;
    }
  }

  render() {
    const ctx = this.ctx;
    ctx.clearRect(0, 0, W, H);

    switch (this.state) {
      case STATE.MENU:       this.renderMenu(ctx); break;
      case STATE.HOWTOPLAY:  this.renderHowToPlay(ctx); break;
      case STATE.PLAYING:    this.renderPlaying(ctx); break;
      case STATE.LEVELCLEAR: this.renderLevelClear(ctx); break;
      case STATE.GAMEOVER:   this.renderGameOver(ctx); break;
    }

    drawScanlines(ctx);
    drawCrosshair(ctx, this.input.mouseX, this.input.mouseY);
  }

  renderMenu(ctx) {
    drawBackground(ctx);

    for (const e of this.demoEnemies) e.render(ctx);

    // Dark overlay
    ctx.fillStyle = 'rgba(10,10,18,0.6)';
    ctx.fillRect(0, 0, W, H);

    // Animated title
    const yOff = Math.sin(this.titleTimer * 1.5) * 4;
    ctx.fillStyle = COL.PLAYER_VISOR;
    ctx.font = 'bold 72px monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.shadowColor = COL.PLAYER_VISOR;
    ctx.shadowBlur = 20 + Math.sin(this.titleTimer * 2) * 8;
    ctx.fillText('PIANO', W / 2, 180 + yOff);
    ctx.shadowBlur = 0;

    ctx.fillStyle = '#aaaaaa';
    ctx.font = '14px monospace';
    ctx.fillText('TOP-DOWN SHOOTER', W / 2, 230);

    // Blinking start
    if (Math.floor(this.menuBlink * 2.5) % 2 === 0) {
      ctx.fillStyle = COL.SCORE;
      ctx.font = 'bold 18px monospace';
      ctx.fillText('[ ENTER ] START', W / 2, 320);
    }

    ctx.fillStyle = '#666688';
    ctx.font = '14px monospace';
    ctx.fillText('[ H ] HOW TO PLAY', W / 2, 360);

    // Version / credit
    ctx.fillStyle = '#333355';
    ctx.font = '10px monospace';
    ctx.fillText('v1.0  •  WASD + MOUSE  •  2026', W / 2, H - 20);
  }

  renderHowToPlay(ctx) {
    drawBackground(ctx);
    ctx.fillStyle = 'rgba(10,10,18,0.85)';
    ctx.fillRect(0, 0, W, H);

    ctx.fillStyle = COL.PLAYER_VISOR;
    ctx.font = 'bold 28px monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('HOW TO PLAY', W / 2, 50);

    ctx.textAlign = 'left';
    ctx.font = '13px monospace';

    const sections = [
      { title: '— CONTROLS —', color: COL.SCORE, items: [
        'WASD / ARROWS   Move',
        'MOUSE           Aim',
        'LEFT CLICK HOLD Auto-fire',
        'ENTER           Confirm / Start',
        'ESC             Menu / Pause',
      ]},
      { title: '— ENEMIES —', color: '#ff88aa', items: [
        '▲  SCOUT     30HP  • Fast • 50pts',
        '■  BRUTE    120HP  • Heavy • 150pts',
        '○  SPECTER   45HP  • Erratic • 100pts',
        '▣  TANK     300HP  • Slow boss • 300pts',
      ]},
      { title: '— TIPS —', color: '#88ffcc', items: [
        'After taking damage you are invincible for 2s',
        'Clear all waves to advance to the next sector',
        'Bonus points awarded at each sector clear',
        'After Sector 4: endless mode begins!',
      ]},
    ];

    let y = 110;
    for (const sec of sections) {
      ctx.fillStyle = sec.color;
      ctx.font = 'bold 14px monospace';
      ctx.fillText(sec.title, 80, y);
      y += 24;
      ctx.font = '12px monospace';
      for (const item of sec.items) {
        ctx.fillStyle = COL.WHITE;
        ctx.fillText(item, 100, y);
        y += 20;
      }
      y += 10;
    }

    if (Math.floor(this.menuBlink * 2.5) % 2 === 0) {
      ctx.fillStyle = '#888899';
      ctx.font = '13px monospace';
      ctx.textAlign = 'center';
      ctx.fillText('[ ESC / ENTER ] BACK', W / 2, H - 25);
    }
  }

  renderPlaying(ctx) {
    // Apply shake
    ctx.save();
    this.shake.apply(ctx);

    drawBackground(ctx);
    this.particles.render(ctx);
    this.waveManager.render(ctx);
    for (const b of this.bullets) b.render(ctx);
    this.player.render(ctx);

    ctx.restore();

    // HUD (no shake)
    const waveNum = this.getCurrentWaveDisplay();
    const totalW = this.getTotalWaves();
    const lvlNum = this.isEndless ? 'X' : this.levelIndex + 1;
    drawHUD(ctx, this.player, this.score, lvlNum, waveNum, totalW);

    // Level title (top center)
    ctx.fillStyle = COL.WHITE;
    ctx.font = '11px monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText(this.getCurrentLevelTitle(), W / 2, 8);
    ctx.textBaseline = 'middle';
  }

  renderLevelClear(ctx) {
    drawBackground(ctx);

    ctx.fillStyle = 'rgba(10,10,18,0.75)';
    ctx.fillRect(0, 0, W, H);

    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';

    ctx.fillStyle = COL.SCORE;
    ctx.shadowColor = COL.SCORE;
    ctx.shadowBlur = 20;
    ctx.font = 'bold 40px monospace';
    ctx.fillText('LEVEL CLEAR!', W / 2, H / 2 - 60);
    ctx.shadowBlur = 0;

    const title = this.levelIndex < LEVELS.length
      ? LEVELS[this.levelIndex].title
      : 'SECTOR ' + (this.levelIndex + 1);
    ctx.fillStyle = '#cccccc';
    ctx.font = '18px monospace';
    ctx.fillText(title + ' COMPLETE', W / 2, H / 2 - 10);

    ctx.fillStyle = '#22d3ee';
    ctx.font = 'bold 22px monospace';
    ctx.fillText(`BONUS +${this.levelClearBonus}`, W / 2, H / 2 + 35);

    ctx.fillStyle = COL.SCORE;
    ctx.font = '16px monospace';
    ctx.fillText(`TOTAL SCORE: ${this.score}`, W / 2, H / 2 + 75);

    if (Math.floor(this.menuBlink * 2) % 2 === 0) {
      ctx.fillStyle = '#888899';
      ctx.font = '13px monospace';
      ctx.fillText('[ ENTER ] CONTINUE', W / 2, H / 2 + 115);
    }
  }

  renderGameOver(ctx) {
    drawBackground(ctx);

    ctx.fillStyle = 'rgba(0,0,0,0.78)';
    ctx.fillRect(0, 0, W, H);

    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';

    ctx.fillStyle = '#ef4444';
    ctx.shadowColor = '#ef4444';
    ctx.shadowBlur = 25;
    ctx.font = 'bold 52px monospace';
    ctx.fillText('GAME OVER', W / 2, H / 2 - 80);
    ctx.shadowBlur = 0;

    ctx.fillStyle = COL.SCORE;
    ctx.font = 'bold 24px monospace';
    ctx.fillText(`SCORE: ${String(this.finalScore).padStart(7, '0')}`, W / 2, H / 2);

    ctx.fillStyle = '#aaaaaa';
    ctx.font = '16px monospace';
    ctx.fillText(`REACHED: LEVEL ${this.finalLevel}`, W / 2, H / 2 + 45);

    if (Math.floor(this.menuBlink * 2) % 2 === 0) {
      ctx.fillStyle = COL.SCORE;
      ctx.font = 'bold 18px monospace';
      ctx.fillText('[ ENTER ] PLAY AGAIN', W / 2, H / 2 + 100);
    }

    ctx.fillStyle = '#555566';
    ctx.font = '13px monospace';
    ctx.fillText('[ ESC ] MENU', W / 2, H / 2 + 135);
  }

  loop(ts) {
    const dt = Math.min((ts - this.lastTime) / 1000, FPS_CAP);
    this.lastTime = ts;

    this.update(dt);
    this.render();

    requestAnimationFrame(ts => this.loop(ts));
  }

  start() {
    requestAnimationFrame(ts => {
      this.lastTime = ts;
      this.loop(ts);
    });
  }
}

// ============================================================
// SECTION 12: BOOTSTRAP
// ============================================================
const canvas = document.getElementById('gameCanvas');

// Scale canvas to fill viewport while maintaining aspect ratio
function resizeCanvas() {
  const ww = window.innerWidth;
  const wh = window.innerHeight;
  const scale = Math.min(ww / W, wh / H);
  canvas.style.width  = Math.floor(W * scale) + 'px';
  canvas.style.height = Math.floor(H * scale) + 'px';
}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

const game = new Game(canvas);
game.start();

</script>
